# ============================================================
# AlcancIA — Variables de Entorno
# ============================================================
# Copiá este archivo como .env y completá los valores.
# Las variables con NEXT_PUBLIC_ son visibles en el frontend.
# ============================================================

# ---- Base de Datos (Supabase Postgres + Prisma) ----
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ---- Supabase (opcional, si usás Supabase directamente) ----
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[TU_ANON_KEY]"

# ---- OpenAI (para el agente IA) ----
OPENAI_API_KEY="sk-..."

# ---- LangSmith (observabilidad del agente, opcional) ----
LANGCHAIN_TRACING_V2="false"
LANGCHAIN_API_KEY=""
LANGCHAIN_PROJECT="alcancia"
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"

# ---- WalletConnect / Reown AppKit ----
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID="[TU_PROJECT_ID_DE_REOWN_CLOUD]"

# ---- Rootstock Network ----
NEXT_PUBLIC_RSK_TESTNET_RPC="https://public-node.testnet.rsk.co"
NEXT_PUBLIC_RSK_MAINNET_RPC="https://public-node.rsk.co"
NEXT_PUBLIC_RSK_EXPLORER_TESTNET="https://explorer.testnet.rootstock.io"
NEXT_PUBLIC_RSK_EXPLORER_MAINNET="https://explorer.rootstock.io"
NEXT_PUBLIC_CHAIN_ID="31"

# ---- Contratos propios (después del deploy) ----
NEXT_PUBLIC_VAULT_MANAGER_ADDRESS=""
NEXT_PUBLIC_STRATEGY_EXECUTOR_ADDRESS=""
NEXT_PUBLIC_REMITTANCE_SCHEDULER_ADDRESS=""

# ---- Money on Chain (Testnet) ----
NEXT_PUBLIC_MOC_CONTRACT_ADDRESS="0x2820f6d4D199B8D8838A4B26F9917754B86a0c1F"
NEXT_PUBLIC_MOC_DOC_TOKEN_ADDRESS=""
NEXT_PUBLIC_MOC_VENDORS_ADDRESS="0x84b895A1b7be8fAc64d43757479281Bf0b5E3719"

# ---- Tropykus (Testnet) ----
NEXT_PUBLIC_TROPYKUS_KDOC_ADDRESS="0x26905F629D17C6ECCE71bC017a9518993Bbbc579"
NEXT_PUBLIC_TROPYKUS_COMPTROLLER_ADDRESS="0xb1BEc5376929b4E0235F1353819DBa92c4B0C6bb"

# ---- Feature Flags (real vs mock) ----
NEXT_PUBLIC_ENABLE_REAL_MOC="false"
NEXT_PUBLIC_ENABLE_REAL_TROPYKUS="false"
NEXT_PUBLIC_ENABLE_REAL_PRICE_ORACLE="true"
NEXT_PUBLIC_ENABLE_REAL_FIAT_RATES="false"
ENABLE_AGENT_LANGSMITH="false"

# ---- Precios y Tasas (fallback/mock) ----
MOCK_BTC_USD_PRICE="65000"
MOCK_TROPYKUS_APY="5.5"
MOCK_USD_ARS_RATE="1250"

# ---- Deploy de Contratos (Hardhat) ----
DEPLOYER_PRIVATE_KEY=""
RSK_TESTNET_RPC="https://public-node.testnet.rsk.co"
RSK_MAINNET_RPC="https://public-node.rsk.co"

# ---- Vercel (deploy) ----
VERCEL_ORG_ID=""
VERCEL_PROJECT_ID=""

# ---- Entorno general ----
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
AGENT_PORT="3001"
