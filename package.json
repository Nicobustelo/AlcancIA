{
  "name": "beexo-agent-yield",
  "version": "0.1.0",
  "private": true,
  "description": "Beexo AgentYield — AI-powered DeFi yield + remittance platform on Rootstock",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:contracts": "pnpm --filter contracts test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "db:generate": "pnpm --filter @beexo/db generate",
    "db:migrate": "pnpm --filter @beexo/db migrate",
    "db:seed": "pnpm --filter @beexo/db seed",
    "deploy:testnet": "pnpm --filter contracts deploy:testnet",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "playwright": "^1.58.2",
    "prettier": "^3.2.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.0.0"
  }
}
