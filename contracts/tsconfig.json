{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "declaration": true,
    "types": ["node", "hardhat", "mocha", "chai"]
  },
  "include": [
    "./hardhat.config.ts",
    "./scripts/**/*",
    "./test/**/*",
    "./typechain-types/hardhat.d.ts"
  ]
}
